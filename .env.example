# Helius API key — used client-side for RPC + Enhanced Transactions.
# Get one at https://dev.helius.xyz. Free tier is fine for v1.
NEXT_PUBLIC_HELIUS_API_KEY=

# --- Analytics (first-party, anonymous, aggregate-only) --------------------
# Password for the /admin dashboard. HTTP Basic Auth — any username works.
# Leave blank to lock /admin for everyone.
ANALYTICS_TOKEN=
# Pepper for the anonymous visitor hash. Set to a long random string.
ANALYTICS_SALT=
# Upstash Redis REST credentials. The Vercel Upstash Marketplace integration
# injects these automatically as KV_REST_API_URL / KV_REST_API_TOKEN (the code
# also accepts UPSTASH_REDIS_REST_URL / _TOKEN). Until both are set, analytics
# is a silent no-op.
KV_REST_API_URL=
KV_REST_API_TOKEN=
